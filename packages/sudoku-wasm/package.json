{
  "name": "sudoku-wasm",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./pkg/index.js",
  "types": "./pkg/index.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "import": "./pkg/index.js"
    },
    "./bindings": "./bindings/index.ts"
  },
  "sideEffects": [
    "./pkg/snippets/*"
  ],
  "files": [
    "./pkg/index_bg.wasm",
    "./pkg/index.js",
    "./pkg/index.d.ts",
    "./bindings"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg --out-name index --release",
    "dev": "wasm-pack build --target web --out-dir pkg --out-name index --dev",
    "lint": "cargo clippy -- -D warnings",
    "lint:fix": "cargo clippy --fix --allow-dirty --allow-staged -- -D warnings",
    "format:fix": "cargo fmt",
    "format": "cargo fmt --check",
    "test": "cargo test",
    "check-types": "cargo check",
    "publish:wasm": "npm pack"
  },
  "dependencies": {
    "sudoku-core": "workspace:*"
  }
}
