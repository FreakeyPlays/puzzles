{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "target/release/**", "pkg/**"],
      "passThroughEnv": ["GIT_HASH"]
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "format": {},
    "format:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "build:android": {
      "cache": false,
      "inputs": ["twa/**"],
      "outputs": ["twa/*.apk", "twa/*.aab"]
    },
    "publish:web": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "DEPLOY_BRANCH"
      ]
    }
  }
}
