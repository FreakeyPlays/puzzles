{
  "name": "puzzles",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start --filter='./apps/*'",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --check \"**/*.{ts,html,json,css,md}\" && turbo run format",
    "format:fix": "prettier --write \"**/*.{ts,html,json,css,md}\" && turbo run format:fix",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "publish:web": "turbo run publish:web",
    "build:android": "turbo run build:android",
    "changeset:version": "changeset version && bun ./scripts/sync-cargo-versions.ts && bun ./scripts/bump-apk-versions.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "wasm-pack": "^0.15.0",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/sudoku-web/**/*.{ts,html}": "bash -c 'bun run --filter=sudoku-web lint:fix' --",
    "packages/sudoku-core/**/*.rs": "bash -c 'bun run --filter=sudoku-core lint:fix && bun run --filter=sudoku-core format:fix' --",
    "packages/sudoku-wasm/**/*.rs": "bash -c 'bun run --filter=sudoku-wasm lint:fix && bun run --filter=sudoku-wasm format:fix' --",
    "*.{ts,html,json,css,md}": "prettier --write --ignore-unknown"
  }
}
